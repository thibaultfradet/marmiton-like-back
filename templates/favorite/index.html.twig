{% extends 'base.html.twig' %}

{% block title %}Mes favoris - Marmiton{% endblock %}

{% block body %}
    <div>
        {# Header #}
        <div class="mb-8">
            <h1 class="text-2xl font-bold text-foreground">Mes favoris</h1>
            <p class="text-sm text-muted-foreground mt-1">{{ recipes|length }} recette{{ recipes|length > 1 ? 's' : '' }}</p>
        </div>

        {% if recipes is empty %}
            <div class="bg-card text-card-foreground rounded-lg border border-border shadow-sm p-12 text-center">
                <svg class="h-12 w-12 mx-auto mb-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/>
                </svg>
                <p class="text-muted-foreground mb-4">Vous n'avez pas encore de recette en favori.</p>
                <a href="{{ path('app_home') }}" class="inline-flex items-center gap-2 rounded-md bg-primary text-primary-foreground font-medium py-2 px-4 text-sm hover:bg-primary/90 transition-colors">
                    Découvrir des recettes
                </a>
            </div>
        {% else %}
            <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
                {% for recipe in recipes %}
                    <div class="relative bg-card text-card-foreground rounded-lg border border-border shadow-sm hover:shadow-md transition-shadow overflow-hidden">
                        {# Favorite heart button #}
                        <button
                            type="button"
                            class="absolute top-3 right-3 z-10"
                            data-controller="favorite"
                            data-favorite-recipe-id-value="{{ recipe.id }}"
                            data-favorite-favorited-value="true"
                            data-action="click->favorite#toggle"
                        >
                            <span data-favorite-target="icon"></span>
                        </button>

                        <a href="{{ path('app_recipe_show', {id: recipe.id}) }}" class="block">
                            {# Recipe photo #}
                            {% set photoUrl = recipe_photo_url(recipe.id) %}
                            {% if photoUrl %}
                                <img src="{{ photoUrl }}" alt="{{ recipe.label }}" class="w-full h-40 object-cover">
                            {% endif %}

                          <div class="p-5">
                            {# Title + category badge #}
                            <div class="flex items-start justify-between gap-2 mb-2">
                                <h3 class="text-base font-semibold text-foreground leading-tight">{{ recipe.label }}</h3>
                                {% if recipe.category %}
                                    <span class="shrink-0 inline-flex items-center px-2 py-0.5 rounded-full bg-secondary text-secondary-foreground text-xs font-medium">
                                        {{ recipe.category.label }}
                                    </span>
                                {% endif %}
                            </div>

                            {# Description #}
                            {% if recipe.description %}
                                <p class="text-sm text-muted-foreground mb-3 line-clamp-2">{{ recipe.description }}</p>
                            {% endif %}

                            {# Meta #}
                            <div class="flex items-center gap-4 text-xs text-muted-foreground mb-3">
                                {% if recipe.preparationTime %}
                                    <span class="inline-flex items-center gap-1">
                                        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path stroke-linecap="round" stroke-linejoin="round" d="M12 6v6l4 2"/></svg>
                                        {{ recipe.preparationTime }} min prépa
                                    </span>
                                {% endif %}
                                {% if recipe.cookingTime %}
                                    <span class="inline-flex items-center gap-1">
                                        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M12 2v4m0 12v4m10-10h-4M6 12H2m15.07-5.07l-2.83 2.83M9.76 14.24l-2.83 2.83m11.14 0l-2.83-2.83M9.76 9.76L6.93 6.93"/></svg>
                                        {{ recipe.cookingTime }} min cuisson
                                    </span>
                                {% endif %}
                                {% if recipe.quantity %}
                                    <span class="inline-flex items-center gap-1">
                                        <svg class="h-3.5 w-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M15.75 6.75a3.75 3.75 0 11-7.5 0 3.75 3.75 0 017.5 0zM4.501 20.118a7.5 7.5 0 0114.998 0"/></svg>
                                        {{ recipe.quantity }} pers.
                                    </span>
                                {% endif %}
                            </div>

                            {# Tags #}
                            {% if recipe.tags|length > 0 %}
                                <div class="flex flex-wrap gap-1.5 mb-3">
                                    {% for tag in recipe.tags %}
                                        <span class="inline-flex items-center px-2 py-0.5 rounded-full bg-accent text-accent-foreground text-xs">
                                            {{ tag.label }}
                                        </span>
                                    {% endfor %}
                                </div>
                            {% endif %}

                            {# Author #}
                            {% if recipe.author %}
                                <div class="flex items-center gap-2 pt-3 border-t border-border">
                                    <span class="inline-flex items-center justify-center h-6 w-6 rounded-full bg-primary text-primary-foreground text-[10px] font-semibold">
                                        {{ recipe.author.firstName|first|upper }}{{ recipe.author.lastName|first|upper }}
                                    </span>
                                    <span class="text-xs text-muted-foreground">
                                        {{ recipe.author.firstName }} {{ recipe.author.lastName|first }}.
                                    </span>
                                </div>
                            {% endif %}
                          </div>
                        </a>
                    </div>
                {% endfor %}
            </div>
        {% endif %}
    </div>
{% endblock %}
