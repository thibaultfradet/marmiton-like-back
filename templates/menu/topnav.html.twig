{# Top navigation bar - included in base.html.twig #}
<header class="bg-card border-b border-border sticky top-0 z-50" data-controller="mobile-menu">
    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <div class="flex items-center justify-between h-16">

            {# Logo #}
            <div class="shrink-0">
                <a href="{{ path('app_home') }}" class="text-2xl font-bold text-primary">
                    Marmiton
                </a>
            </div>

            {# Desktop search bar + create button #}
            <div class="hidden md:flex flex-1 max-w-sm mx-6 items-center">
                <form class="w-full" action="#" method="GET">
                    <div class="relative">
                        <input
                            type="text"
                            name="q"
                            placeholder="Rechercher une recette..."
                            class="w-full rounded-l-md border border-input bg-background py-2 pl-4 pr-10 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
                        >
                        <button type="submit" class="absolute right-3 top-1/2 -translate-y-1/2 text-muted-foreground hover:text-primary">
                            <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z"/>
                            </svg>
                        </button>
                    </div>
                </form>
                <a href="{{ path('app_recipe_new') }}" class="inline-flex items-center justify-center h-9.5 px-3 rounded-r-md border border-l-0 border-input bg-primary text-primary-foreground hover:bg-primary/90 transition-colors" title="Nouvelle recette">
                    <svg class="h-4 w-4" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
                    </svg>
                </a>
            </div>

            {# Desktop user area #}
            <div class="hidden md:flex items-center">
                {% if app.user %}
                    <div data-controller="dropdown" class="relative">
                        <button
                            data-action="click->dropdown#toggle"
                            class="flex items-center space-x-2 text-foreground hover:text-primary focus:outline-none transition-colors"
                        >
                            {# Avatar with initials #}
                            <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-primary text-primary-foreground text-xs font-semibold">
                                {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
                            </span>
                            <span class="text-sm font-medium">
                                {{ app.user.firstName }} {{ app.user.lastName|first }}.
                            </span>
                            <svg class="h-4 w-4 text-muted-foreground" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M19 9l-7 7-7-7"/>
                            </svg>
                        </button>

                        {# Dropdown menu #}
                        <div
                            data-dropdown-target="menu"
                            class="hidden absolute right-0 mt-2 w-48 rounded-md bg-popover text-popover-foreground border border-border shadow-md py-1 z-50"
                        >
                            <a href="{{ path('app_recipe_my') }}" class="block px-4 py-2 text-sm text-foreground hover:bg-accent transition-colors">
                                Mes recettes
                            </a>
                            {% if is_granted('ROLE_ADMIN') %}
                                <a href="{{ path('app_admin_settings') }}" class="block px-4 py-2 text-sm text-foreground hover:bg-accent transition-colors">
                                    Paramétrage
                                </a>
                            {% endif %}
                            <div class="border-t border-border my-1"></div>
                            <a href="{{ logout_path() }}" class="block px-4 py-2 text-sm text-destructive hover:bg-accent transition-colors">
                                Déconnexion
                            </a>
                        </div>
                    </div>
                {% else %}
                    <a
                        href="{{ path('app_login') }}"
                        class="inline-flex items-center rounded-md bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90 transition-colors"
                    >
                        Se connecter
                    </a>
                {% endif %}
            </div>

            {# Mobile hamburger button #}
            <div class="md:hidden flex items-center">
                <button
                    data-action="click->mobile-menu#toggle"
                    class="text-foreground hover:text-primary focus:outline-none"
                >
                    <svg data-mobile-menu-target="openIcon" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
                    </svg>
                    <svg data-mobile-menu-target="closeIcon" class="h-6 w-6 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                    </svg>
                </button>
            </div>
        </div>
    </div>

    {# Mobile menu panel #}
    <div data-mobile-menu-target="menu" class="hidden md:hidden border-t border-border bg-card">
        <div class="px-4 py-4 space-y-3">
            {# Mobile search #}
            <form action="#" method="GET">
                <input
                    type="text"
                    name="q"
                    placeholder="Rechercher une recette..."
                    class="w-full rounded-md border border-input bg-background py-2 px-4 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2 focus:ring-ring"
                >
            </form>

            {# Mobile navigation links #}
            {% if app.user %}
                <div class="space-y-1 border-b border-border pb-3">
                    <a href="{{ path('app_recipe_new') }}" class="flex items-center gap-2 py-2 text-sm font-medium text-foreground hover:text-primary transition-colors">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 4.5v15m7.5-7.5h-15"/>
                        </svg>
                        Nouvelle recette
                    </a>
                    <a href="{{ path('app_recipe_my') }}" class="flex items-center gap-2 py-2 text-sm font-medium text-foreground hover:text-primary transition-colors">
                        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M12 6.042A8.967 8.967 0 006 3.75c-1.052 0-2.062.18-3 .512v14.25A8.987 8.987 0 016 18c2.305 0 4.408.867 6 2.292m0-14.25a8.966 8.966 0 016-2.292c1.052 0 2.062.18 3 .512v14.25A8.987 8.987 0 0018 18a8.967 8.967 0 00-6 2.292m0-14.25v14.25"/>
                        </svg>
                        Mes recettes
                    </a>
                    {% if is_granted('ROLE_ADMIN') %}
                        <a href="{{ path('app_admin_settings') }}" class="flex items-center gap-2 py-2 text-sm font-medium text-foreground hover:text-primary transition-colors">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M9.594 3.94c.09-.542.56-.94 1.11-.94h2.593c.55 0 1.02.398 1.11.94l.213 1.281c.063.374.313.686.645.87.074.04.147.083.22.127.325.196.72.257 1.075.124l1.217-.456a1.125 1.125 0 011.37.49l1.296 2.247a1.125 1.125 0 01-.26 1.431l-1.003.827c-.293.241-.438.613-.43.992a7.723 7.723 0 010 .255c-.008.378.137.75.43.991l1.004.827c.424.35.534.955.26 1.43l-1.298 2.247a1.125 1.125 0 01-1.369.491l-1.217-.456c-.355-.133-.75-.072-1.076.124a6.47 6.47 0 01-.22.128c-.331.183-.581.495-.644.869l-.213 1.281c-.09.543-.56.941-1.11.941h-2.594c-.55 0-1.019-.398-1.11-.94l-.213-1.281c-.062-.374-.312-.686-.644-.87a6.52 6.52 0 01-.22-.127c-.325-.196-.72-.257-1.076-.124l-1.217.456a1.125 1.125 0 01-1.369-.49l-1.297-2.247a1.125 1.125 0 01.26-1.431l1.004-.827c.292-.24.437-.613.43-.991a6.932 6.932 0 010-.255c.007-.38-.138-.751-.43-.992l-1.004-.827a1.125 1.125 0 01-.26-1.43l1.297-2.247a1.125 1.125 0 011.37-.491l1.216.456c.356.133.751.072 1.076-.124.072-.044.146-.086.22-.128.332-.183.582-.495.644-.869l.214-1.28z"/>
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z"/>
                            </svg>
                            Paramétrage
                        </a>
                    {% endif %}
                </div>

            {# Mobile user section #}
                <div class="flex items-center space-x-2 py-2">
                    <span class="inline-flex items-center justify-center h-8 w-8 rounded-full bg-primary text-primary-foreground text-xs font-semibold">
                        {{ app.user.firstName|first|upper }}{{ app.user.lastName|first|upper }}
                    </span>
                    <span class="text-sm font-medium text-foreground">
                        {{ app.user.firstName }} {{ app.user.lastName|first }}.
                    </span>
                </div>
                <a href="{{ logout_path() }}" class="block py-2 text-sm text-destructive hover:text-destructive/80 transition-colors">Déconnexion</a>
            {% else %}
                <a
                    href="{{ path('app_login') }}"
                    class="block text-center rounded-md bg-primary text-primary-foreground px-4 py-2 text-sm font-medium hover:bg-primary/90 transition-colors"
                >
                    Se connecter
                </a>
            {% endif %}
        </div>
    </div>
</header>
