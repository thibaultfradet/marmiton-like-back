{% extends 'base.html.twig' %}

{% block title %}Modifier {{ user.firstName }} {{ user.lastName }} - Marmiton{% endblock %}

{# Macro for consistent input classes with red border on error #}
{% macro input_class(field, extra) %}
{%- apply spaceless -%}
w-full rounded-md border bg-background px-3 py-2 text-sm placeholder:text-muted-foreground focus:outline-none focus:ring-2
{%- if field.vars.errors|length > 0 %} border-destructive focus:ring-destructive{% else %} border-input focus:ring-ring{% endif -%}
{%- if extra %} {{ extra }}{% endif -%}
{%- endapply -%}
{% endmacro %}

{% block body %}
    <div class="max-w-2xl mx-auto">
        <div class="mb-8">
            <h1 class="text-2xl font-bold text-foreground">Modifier l'utilisateur</h1>
            <p class="text-sm text-muted-foreground mt-1">{{ user.firstName }} {{ user.lastName }}</p>
        </div>

        <div class="bg-card text-card-foreground rounded-lg border border-border shadow-sm p-6">
            {{ form_start(form, {'attr': {'class': 'space-y-6', 'novalidate': 'novalidate'}}) }}

                {# Name fields row #}
                <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
                    <div>
                        {{ form_label(form.firstName, null, {'label_attr': {'class': 'block text-sm font-medium mb-1.5'}}) }}
                        {{ form_widget(form.firstName, {'attr': {'class': _self.input_class(form.firstName)}}) }}
                        {{ form_errors(form.firstName, {'attr': {'class': 'text-destructive text-sm mt-1'}}) }}
                    </div>
                    <div>
                        {{ form_label(form.lastName, null, {'label_attr': {'class': 'block text-sm font-medium mb-1.5'}}) }}
                        {{ form_widget(form.lastName, {'attr': {'class': _self.input_class(form.lastName)}}) }}
                        {{ form_errors(form.lastName, {'attr': {'class': 'text-destructive text-sm mt-1'}}) }}
                    </div>
                </div>

                {# Email #}
                <div>
                    {{ form_label(form.email, null, {'label_attr': {'class': 'block text-sm font-medium mb-1.5'}}) }}
                    {{ form_widget(form.email, {'attr': {'class': _self.input_class(form.email)}}) }}
                    {{ form_errors(form.email, {'attr': {'class': 'text-destructive text-sm mt-1'}}) }}
                </div>

                {# Roles #}
                <div>
                    {{ form_label(form.roles, null, {'label_attr': {'class': 'block text-sm font-medium mb-1.5'}}) }}
                    <div class="flex flex-wrap gap-4 mt-1">
                        {% for child in form.roles %}
                            <label class="inline-flex items-center gap-2 text-sm text-foreground">
                                {{ form_widget(child, {'attr': {'class': 'rounded border-input text-primary focus:ring-ring'}}) }}
                                {{ child.vars.label }}
                            </label>
                        {% endfor %}
                    </div>
                    {{ form_errors(form.roles, {'attr': {'class': 'text-destructive text-sm mt-1'}}) }}
                </div>

                {# Actions #}
                <div class="flex items-center justify-between pt-4">
                    <a href="{{ path('app_admin_users') }}" class="text-sm text-muted-foreground hover:text-foreground transition-colors">
                        Annuler
                    </a>
                    <button type="submit" class="rounded-md bg-primary text-primary-foreground font-medium py-2 px-6 text-sm hover:bg-primary/90 focus:outline-none focus:ring-2 focus:ring-ring focus:ring-offset-2 transition-colors">
                        Enregistrer les modifications
                    </button>
                </div>

            {{ form_end(form) }}
        </div>
    </div>
{% endblock %}
